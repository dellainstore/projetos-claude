# Bling OAuth2 (API v3)
# Criar app em: https://developer.bling.com.br/aplicativos
BLING_CLIENT_ID=seu-client-id
BLING_CLIENT_SECRET=seu-client-secret
# URL de callback registrada no app Bling (deve ser HTTPS em produção)
BLING_REDIRECT_URI=https://www.dellainstore.com.br/bling/callback/

# WhatsApp (números para botão flutuante)
WHATSAPP_NUMBER_1=5511999999999
WHATSAPP_NUMBER_2=5511888888888

# Instagram
INSTAGRAM_ACCESS_TOKEN=seu-token-instagram

# Melhor Envio
MELHOR_ENVIO_TOKEN=seu-token-melhor-envio
MELHOR_ENVIO_SANDBOX=True

# Pix (chave: CPF, CNPJ, e-mail, telefone ou chave aleatória)
PIX_CHAVE=seu-email@dellainstore.com.br
