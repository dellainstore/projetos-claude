# ── Django ────────────────────────────────────────────────────────────────────
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=sua-secret-key-aqui

# Em produção: False
DEBUG=False

# Ex: sistemas.dellastore.com.br,localhost
ALLOWED_HOSTS=sistemas.dellastore.com.br

# ── Banco de dados dos Produtos ───────────────────────────────────────────────
# Caminho absoluto para o inclusoes.db (banco do módulo produtos)
PRODUTOS_DB_PATH=/var/www/della-sistemas/projetos-claude/della_sistemas/data/produtos/inclusoes.db

# ── Bling OAuth ───────────────────────────────────────────────────────────────
BLING_AUTH_DIR=/var/www/della-sistemas/shared/bling_auth
BLING_CLIENT_ID=seu-client-id-bling
BLING_CLIENT_SECRET=seu-client-secret-bling
BLING_DEPOSITO_ID=seu-deposito-id
