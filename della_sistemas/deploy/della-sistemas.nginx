# Nginx — D'ELLA Sistemas
# Instalar em: /etc/nginx/sites-available/della-sistemas
# Ativar com: sudo ln -s /etc/nginx/sites-available/della-sistemas /etc/nginx/sites-enabled/

# Redireciona HTTP → HTTPS
server {
    listen 80;
    server_name sistemas.dellainstore.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name sistemas.dellainstore.com;

    # SSL (Certbot vai preencher automaticamente)
    ssl_certificate     /etc/letsencrypt/live/sistemas.dellainstore.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/sistemas.dellainstore.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # Security headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Proxy para o Gunicorn (Unix socket)
    location / {
        proxy_pass         http://unix:/run/della-sistemas/gunicorn.sock;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # Arquivos estáticos servidos diretamente pelo Nginx (mais rápido)
    location /static/ {
        alias /var/www/della-sistemas/projetos-claude/della_sistemas/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}
